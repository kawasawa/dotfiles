{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.7-code",
  "small_model": "opencode-go/deepseek-v4-flash",
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*.keystore": "deny",
      ".ssh/*": "deny",
      ".aws/*": "deny"
    },
    "bash": {
      "*": "ask",
      "sudo *": "deny",
      "rm -rf *": "deny",
      "git reset --hard *": "deny",
      "gh repo delete *": "deny",
      "gh auth token *": "deny",
      "rm *": "ask",
      "chmod *": "ask",
      "curl *": "ask",
      "wget *": "ask",
      "git checkout *": "ask",
      "git switch *": "ask",
      "git pull *": "ask",
      "git clean *": "ask",
      "git reset *": "ask",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git rebase *": "ask",
      "gh pr create *": "ask",
      "gh pr merge *": "ask",
      "ls *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "mkdir *": "allow",
      "wc *": "allow",
      "jq *": "allow",
      "cat *": "allow",
      "sed -n *": "allow",
      "git branch --show-current": "allow",
      "git ls-remote *": "allow",
      "git log *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git --no-pager diff *": "allow",
      "git show *": "allow",
      "git fetch *": "allow",
      "git mv *": "allow",
      "git check-ignore *": "allow",
      "gh repo view *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "npm ls *": "allow",
      "npm list *": "allow",
      "npm view *": "allow",
      "npm test *": "allow",
      "npm run format *": "allow",
      "npm run lint *": "allow",
      "npm run typecheck *": "allow",
      "npm run test *": "allow",
      "npm run build *": "allow",
      "npx prettier *": "allow",
      "npx eslint *": "allow",
      "npx tsc *": "allow",
      "npx jest *": "allow",
      "npx vitest *": "allow",
      "xcodebuild *": "allow"
    }
  }
}
